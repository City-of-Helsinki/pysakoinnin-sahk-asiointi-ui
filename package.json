  "scripts": {
    "app:version": "echo \"$npm_package_version\"",
    "start": "pnpm run update-runtime-env && vite",
    "typecheck": "tsc --skipLibCheck --noEmit --project tsconfig.json",
    "build": "pnpm typecheck && vite build",
    "preview": "pnpm update-runtime-env && vite preview",
    "test": "NODE_ENV=test pnpm run update-runtime-env && vitest --config ./vitest.config.ts",
    "test:coverage": "CI=true pnpm test --coverage",
    "ci": "CI=true pnpm test --coverage",
    "lint": "eslint --ext js,ts,tsx src",
    "update-runtime-env": "esrun --tsconfig=./scripts/tsconfig.json scripts/update-runtime-env.ts",
    "postinstall": "pnpm update-runtime-env",
    "prepare": "husky",
    "test:e2e:install": "pnpm playwright install",
    "test:e2e:ci": "pnpm playwright test",
    "test:e2e:start": "pnpm playwright test",
    "test:e2e:record": "pnpm playwright codegen https://pysakoinnin-sahk-asiointi-ui.dev.hel.ninja/"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
